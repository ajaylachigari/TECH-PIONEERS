                        </p>
                      )}
                      <p className="font-paragraph text-lg text-foreground mb-6">
                        {impact.description}
                      </p>
                      {impact.userBenefit && (
                        <p className="font-paragraph text-base text-foreground">
                          {impact.userBenefit}
                        </p>
                      )}
                    </div>
                  </motion.div>
                ))}
              </div>
            ) : (
              <div className="text-center py-24">
                <p className="font-paragraph text-lg text-foreground">
                  No social impact data available at the moment.
                </p>
              </div>
            )}
          </div>
        </div>
      </section>

      {/* Team Section */}
      <section id="team" className="w-full bg-background">
        <div className="max-w-[100rem] mx-auto px-8 py-32">
