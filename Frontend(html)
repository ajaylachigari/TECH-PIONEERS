            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.6 }}
            className="grid grid-cols-12 gap-24"
          >
            <div className="col-span-12 lg:col-span-5">
              <h2 className="font-heading text-5xl text-primary mb-8">
                Business Impact
              </h2>
              <p className="font-paragraph text-lg text-foreground">
                Transforming the fashion industry with AI-powered personalization
              </p>
            </div>
            <div className="col-span-12 lg:col-span-7">
              <div className="min-h-[300px]">
                {isLoading ? null : businessImpact.length > 0 ? (
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
                    {businessImpact.map((impact, index) => (
                      <motion.div
                        key={impact._id}
                        initial={{ opacity: 0, y: 20 }}
                        whileInView={{ opacity: 1, y: 0 }}
                        viewport={{ once: true }}
                        transition={{ duration: 0.5, delay: index * 0.1 }}
                        className="bg-secondary p-8"
                      >
                        {impact.benefitImage && (
                          <div className="mb-6 h-12">
                            <Image
                              src={impact.benefitImage}
                              alt={impact.impactTitle || 'Impact'}
                              width={100}
                              className="h-full w-auto object-contain"
                            />
                          </div>
                        )}
                        <h3 className="font-heading text-2xl text-primary mb-4">
                          {impact.impactTitle}
                        </h3>
                        {impact.metricValue !== undefined && (
                          <div className="mb-4">
                            <span className="font-heading text-4xl text-accent">
                              {impact.metricValue}
                              {impact.metricUnit}
                            </span>
                          </div>
                        )}
                        <p className="font-paragraph text-base text-foreground">
                          {impact.description}
                        </p>
                      </motion.div>
                    ))}
                  </div>
                ) : (
                  <div className="text-center py-24">
                    <p className="font-paragraph text-lg text-foreground">
                      No business impact data available at the moment.
                    </p>
                  </div>
                )}
              </div>
            </div>
          </motion.div>
        </div>
      </section>

