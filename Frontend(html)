            <h2 className="font-heading text-5xl text-primary mb-6">
              Team Tech Pioneers
            </h2>
            <p className="font-paragraph text-lg text-foreground max-w-3xl mx-auto">
              Meet the innovators behind StyleSense
            </p>
          </motion.div>

          <div className="min-h-[400px]">
            {isLoading ? null : teamMembers.length > 0 ? (
              <div className="grid grid-cols-12 gap-12">
                {teamMembers.map((member, index) => (
                  <motion.div
                    key={member._id}
                    initial={{ opacity: 0, y: 20 }}
                    whileInView={{ opacity: 1, y: 0 }}
                    viewport={{ once: true }}
                    transition={{ duration: 0.5, delay: index * 0.1 }}
                    className="col-span-12 sm:col-span-6 md:col-span-4 lg:col-span-3"
                  >
                    <div className="bg-secondary p-8 text-center h-full">
                      {member.profileImage && (
                        <div className="mb-6 aspect-square mx-auto max-w-[200px]">
                          <Image
                            src={member.profileImage}
                            alt={member.memberName || 'Team Member'}
                            width={200}
                            className="w-full h-full object-cover"
                          />
                        </div>
                      )}
                      <h3 className="font-heading text-xl text-primary mb-2">
                        {member.memberName}
                      </h3>
                      <p className="font-paragraph text-base text-accent mb-4 font-semibold">
                        {member.role}
                      </p>
                      {member.shortBio && (
                        <p className="font-paragraph text-sm text-foreground mb-6">
                          {member.shortBio}
                        </p>
                      )}
                      {member.linkedInProfile && (
                        <a
                          href={member.linkedInProfile}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="font-paragraph text-sm text-primary font-semibold hover:text-accent transition-colors"
                        >
                          LinkedIn Profile
                        </a>
                      )}
                    </div>
                  </motion.div>
                ))}
              </div>
            ) : (
              <div className="text-center py-24">
                <p className="font-paragraph text-lg text-foreground">
                  No team members available at the moment.
                </p>
              </div>
            )}
          </div>
        </div>
      </section>

      {/* Contact Section */}
      <section id="contact" className="w-full bg-secondary">
        <div className="max-w-[100rem] mx-auto px-8 py-32">
          <div className="grid grid-cols-12 gap-24">
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              transition={{ duration: 0.6 }}
              className="col-span-12 lg:col-span-5"
            >
              <h2 className="font-heading text-5xl text-primary mb-8">
                Join the Future of Fashion
              </h2>
              <p className="font-paragraph text-lg text-foreground mb-12">
                Ready to transform your fashion experience? Get in touch with us to learn more 
                about StyleSense and how AI-powered recommendations can revolutionize your wardrobe.
              </p>
              <div className="space-y-6">
                <div className="flex items-center gap-4">
                  <Sparkles className="w-6 h-6 text-accent" />
                  <span className="font-paragraph text-base text-foreground">
                    Personalized AI recommendations
                  </span>
                </div>
                <div className="flex items-center gap-4">
                  <TrendingUp className="w-6 h-6 text-accent" />
                  <span className="font-paragraph text-base text-foreground">
                    Real-time trend analysis
                  </span>
                </div>
                <div className="flex items-center gap-4">
                  <User className="w-6 h-6 text-accent" />
