<div className={col-span-12 lg:col-span-6 ${index % 2 === 1 ? 'lg:col-start-7' : ''}}>
                      <div className="flex items-center gap-6 mb-6">
                        <span className="font-heading text-6xl text-accent">
                          {step.stepNumber}
                        </span>
                        <h3 className="font-heading text-3xl text-primary">
                          {step.stepTitle}
                        </h3>
                      </div>
                      <p className="font-paragraph text-lg text-foreground mb-8">
                        {step.stepDescription}
                      </p>
                      {step.callToActionUrl && (
                        <a
                          href={step.callToActionUrl}
                          className="inline-flex items-center gap-2 font-paragraph text-base text-primary font-semibold hover:text-accent transition-colors"
                        >
                          Learn More
                          <ArrowRight className="w-4 h-4" />
                        </a>
                      )}
                    </div>
                    <div className={col-span-12 lg:col-span-6 ${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}}>
                      {step.stepImage && (
                        <div className="aspect-video">
                          <Image
                            src={step.stepImage}
                            alt={step.stepTitle || Step ${step.stepNumber}}
                            width={800}
                            className="w-full h-full object-cover"
                          />
                        </div>
                      )}
                    </div>
                  </motion.div>
                ))}
              </div>
            ) : (
              <div className="text-center py-24">
                <p className="font-paragraph text-lg text-foreground">
                  No steps available at the moment.
                </p>
              </div>
            )}
          </div>
        </div>
      </section>

      {/* Technology Stack Section */}
      <section id="technology" className="w-full bg-secondary">
        <div className="max-w-[100rem] mx-auto px-8 py-32">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.6 }}
            className="text-center mb-24"
          >
            <h2 className="font-heading text-5xl text-primary mb-6">
              Technology Stack
            </h2>
            <p className="font-paragraph text-lg text-foreground max-w-3xl mx-auto">
              Built with cutting-edge technologies to deliver the best experience
            </p>
          </motion.div>

          <div className="min-h-[400px]">
            {isLoading ? null : techStack.length > 0 ? (
              <div className="space-y-16">
                {['Frontend', 'Backend', 'AI Components'].map((category) => {
                  const categoryTech = techStack.filter(tech => tech.category === category);
                  if (categoryTech.length === 0) return null;

                  return (
                    <motion.div
                      key={category}
                      initial={{ opacity: 0, y: 20 }}
                      whileInView={{ opacity: 1, y: 0 }}
                      viewport={{ once: true }}
                      transition={{ duration: 0.6 }}
                    >
                      <h3 className="font-heading text-3xl text-primary mb-8">
                        {category}
                      </h3>
                      <div className="grid grid-cols-12 gap-8">
                        {categoryTech.map((tech, index) => (
                          <motion.div
                            key={tech._id}
                            initial={{ opacity: 0, y: 20 }}
                            whileInView={{ opacity: 1, y: 0 }}
                            viewport={{ once: true }}
                            transition={{ duration: 0.4, delay: index * 0.1 }}
                            className="col-span-12 sm:col-span-6 md:col-span-4 lg:col-span-3"
                          >
                            <div className="bg-background p-6 h-full">
                              {tech.logo && (
                                <div className="mb-4 h-16 flex items-center justify-center">
                                  <Image
                                    src={tech.logo}
                                    alt={tech.technologyName || 'Technology'}
                                    width={100}
                                    className="max-h-full w-auto object-contain"
                                  />
                                </div>
                              )}
                              <h4 className="font-heading text-xl text-primary mb-3">
                                {tech.technologyName}
                              </h4>
                              <p className="font-paragraph text-sm text-foreground mb-4">
                                {tech.description}
                              </p>
                              {tech.websiteUrl && (
                                <a
                                  href={tech.websiteUrl}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  className="font-paragraph text-sm text-primary font-semibold hover:text-accent transition-colors"
                                >
                                  Learn More
                                </a>
                              )}
                            </div>
                          </motion.div>
                        ))}
                      </div>
                    </motion.div>
                  );
                })}
              </div>
            ) : (
              <div className="text-center py-24">
                <p className="font-paragraph text-lg text-foreground">
                  No technology information available at the moment.
                </p>
              </div>
            )}
          </div>
        </div>
      </section>

